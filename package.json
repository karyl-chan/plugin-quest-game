{
  "name": "@karyl-chan/plugin-quest-game",
  "version": "0.1.0",
  "description": "Discord board-game bot — interactive team-deduction quest game with shared buttons and ephemeral player views (no DM required).",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite build && tsx watch src/index.ts",
    "build": "rm -rf dist && vite build && tsc",
    "build:ui": "vite build",
    "build:server": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "simulate": "tsx scripts/simulate.ts",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.3",
    "@iconify/vue": "^5.0.0",
    "@karyl-chan/plugin-sdk": "^0.10.0",
    "@karyl-chan/ui": "^0.3.0",
    "@popperjs/core": "^2.11.8",
    "cropperjs": "1",
    "nanoid": "^3.3.11",
    "pinia": "^3.0.4",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "fastify": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^4.1.6",
    "vue": "^3.5.13",
    "vue-i18n": "^11.0.0"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
